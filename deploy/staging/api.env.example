DEPLOYMENT_ENV=staging
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
REPOSITORY_BACKEND=postgres
DATABASE_URL=postgres://pilot:pilot@postgres:5432/pilot_platform
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
APP_SECURITY_MODE=secure
AUTH_ALLOW_SEED_TOKENS=false
SESSION_SECRET=replace-with-secure-session-secret
SECURITY_HEADERS_ENABLED=true
RATE_LIMITING_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PUBLIC_MAX=20
RATE_LIMIT_SENSITIVE_MAX=30
RATE_LIMIT_ADMIN_MAX=15
REQUEST_BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=15000
CORS_ALLOW_ORIGINS=https://console.example.com
OIDC_ENABLED=true
OIDC_ISSUER=https://your-issuer.example.com/
OIDC_AUDIENCE=physical-world-interaction-platform
OIDC_CLIENT_ID=physical-world-interaction-platform-web
OIDC_SCOPES=openid profile email
OIDC_ALLOW_EMAIL_FALLBACK=false
IOT_BASE_URL=https://iot-staging.example.com
IOT_EXPECTED_ENVIRONMENT=staging
IOT_EXPECTED_CONTRACT_VERSION=2026-04-17.1
IOT_PRODUCTION_BASE_URL=https://iot-production.example.com
IOT_PRODUCTION_EXPECTED_ENVIRONMENT=production
IOT_PRODUCTION_EXPECTED_CONTRACT_VERSION=2026-04-17.1
IOT_REQUIRE_RELEASE_MANIFEST=true
IOT_RELEASE_MANIFEST_PATH=/app/deploy/release-manifest.json
IOT_ALERT_WEBHOOK_URL_STAGING=https://alerts.example.com/staging
IOT_ALERT_WEBHOOK_URL_PRODUCTION=https://alerts.example.com/production
IOT_ALERT_WEBHOOK_URL_PARITY=https://alerts.example.com/parity
IOT_ALERT_WEBHOOK_URL_CRITICAL=https://alerts.example.com/critical
EXPORT_ENCRYPTION_MODE=kms
BACKUP_ENCRYPTION_CONFIRMED=true
PENTEST_SCHEDULED=false
