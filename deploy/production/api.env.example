DEPLOYMENT_ENV=production
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

REPOSITORY_BACKEND=postgres
DATABASE_URL=postgres://replace-with-managed-db-user:replace-with-managed-db-password@replace-with-managed-db-host:5432/pilot_platform
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_RUNTIME_ROLE=app_runtime

APP_SECURITY_MODE=secure
AUTH_ALLOW_SEED_TOKENS=false
SESSION_SECRET=replace-with-32-plus-character-secret-from-kms-or-vault
SECURITY_HEADERS_ENABLED=true
RATE_LIMITING_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PUBLIC_MAX=20
RATE_LIMIT_SENSITIVE_MAX=30
RATE_LIMIT_ADMIN_MAX=15
REQUEST_BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=15000
CORS_ALLOW_ORIGINS=https://replace-with-production-console-host

OIDC_ENABLED=true
OIDC_ISSUER=https://replace-with-oidc-issuer
OIDC_AUDIENCE=physical-world-interaction-platform
OIDC_CLIENT_ID=physical-world-interaction-platform-web
OIDC_SCOPES=openid profile email
OIDC_ALLOW_EMAIL_FALLBACK=false

IOT_BASE_URL=https://replace-with-iot-production-host
IOT_EXPECTED_ENVIRONMENT=production
IOT_EXPECTED_CONTRACT_VERSION=2026-04-17.1
IOT_REQUIRE_RELEASE_MANIFEST=true
IOT_RELEASE_MANIFEST_PATH=/app/deploy/release-manifest.json
IOT_ALERT_WEBHOOK_URL_PRODUCTION=https://replace-with-production-alert-webhook
IOT_ALERT_WEBHOOK_URL_CRITICAL=https://replace-with-critical-alert-webhook

EXPORT_ENCRYPTION_MODE=kms
BACKUP_ENCRYPTION_CONFIRMED=true
PENTEST_SCHEDULED=false

NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_PROVIDER_MODE=production
NOTIFICATION_EMAIL_PROVIDER_KIND=http_json
NOTIFICATION_EMAIL_PROVIDER_NAME=replace-with-email-provider-name
NOTIFICATION_EMAIL_PROVIDER_URL=https://replace-with-email-provider-endpoint
NOTIFICATION_EMAIL_PROVIDER_TIMEOUT_MS=8000
NOTIFICATION_EMAIL_PROVIDER_AUTH_TYPE=bearer
NOTIFICATION_EMAIL_PROVIDER_AUTH_TOKEN=replace-with-email-provider-token-from-kms
NOTIFICATION_EMAIL_SENDER=no-reply@replace-with-domain.example
NOTIFICATION_EMAIL_WEBHOOK_AUTH_MODE=hmac_sha256
NOTIFICATION_EMAIL_WEBHOOK_SECRET=replace-with-email-webhook-secret-from-kms
NOTIFICATION_EMAIL_WEBHOOK_SIGNATURE_HEADER=x-notification-signature
NOTIFICATION_EMAIL_WEBHOOK_TIMESTAMP_HEADER=x-notification-timestamp
NOTIFICATION_EMAIL_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_SMS_PROVIDER_MODE=not_configured
NOTIFICATION_SMS_PROVIDER_KIND=http_json
NOTIFICATION_SMS_PROVIDER_NAME=replace-with-sms-provider-name
NOTIFICATION_SMS_PROVIDER_URL=https://replace-with-sms-provider-endpoint
NOTIFICATION_SMS_PROVIDER_TIMEOUT_MS=8000
NOTIFICATION_SMS_PROVIDER_AUTH_TYPE=bearer
NOTIFICATION_SMS_PROVIDER_AUTH_TOKEN=replace-with-sms-provider-token-from-kms
NOTIFICATION_SMS_SENDER=replace-with-sms-sender
NOTIFICATION_SMS_WEBHOOK_AUTH_MODE=shared_secret
NOTIFICATION_SMS_WEBHOOK_SECRET=replace-with-sms-webhook-secret-from-kms
NOTIFICATION_SMS_WEBHOOK_SIGNATURE_HEADER=x-notification-signature
NOTIFICATION_SMS_WEBHOOK_TIMESTAMP_HEADER=x-notification-timestamp
NOTIFICATION_SMS_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

NOTIFICATION_WHATSAPP_ENABLED=false
NOTIFICATION_WHATSAPP_PROVIDER_MODE=not_configured
NOTIFICATION_WHATSAPP_PROVIDER_KIND=http_json
NOTIFICATION_WHATSAPP_PROVIDER_NAME=replace-with-whatsapp-provider-name
NOTIFICATION_WHATSAPP_PROVIDER_URL=https://replace-with-whatsapp-provider-endpoint
NOTIFICATION_WHATSAPP_PROVIDER_TIMEOUT_MS=8000
NOTIFICATION_WHATSAPP_PROVIDER_AUTH_TYPE=bearer
NOTIFICATION_WHATSAPP_PROVIDER_AUTH_TOKEN=replace-with-whatsapp-provider-token-from-kms
NOTIFICATION_WHATSAPP_SENDER=replace-with-whatsapp-sender
NOTIFICATION_WHATSAPP_WEBHOOK_AUTH_MODE=shared_secret
NOTIFICATION_WHATSAPP_WEBHOOK_SECRET=replace-with-whatsapp-webhook-secret-from-kms
NOTIFICATION_WHATSAPP_WEBHOOK_SIGNATURE_HEADER=x-notification-signature
NOTIFICATION_WHATSAPP_WEBHOOK_TIMESTAMP_HEADER=x-notification-timestamp
NOTIFICATION_WHATSAPP_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_SECONDS=60
NOTIFICATION_WORKER_BATCH_LIMIT=20
NOTIFICATION_WORKER_TENANT_ID=tenant-demo
NOTIFICATION_WORKER_EVENT_ID=
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MINUTES=15
NOTIFICATION_DEAD_LETTER_ALERT_THRESHOLD=5
