# ── Server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────
SESSION_SECRET=change_me_in_production
PLATFORM_BASE_URL=http://localhost:3000
SUPPORT_EMAIL=support@codex.io

# ── Database ──────────────────────────────────────────────────────
REPOSITORY_BACKEND=memory
# DATABASE_URL=postgres://user:password@localhost:5432/codex_dev
# DATABASE_SSL=false

# ── Storage ───────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/exports/
EXPORT_SECRET=change_me_in_production

# S3 (only needed if STORAGE_BACKEND=s3)
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-south-1
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Infrastructure compliance ──────────────────────────────────────
INFRA_BACKEND=mock
# For AWS: set INFRA_BACKEND=aws and ensure AWS credentials are configured above
# DB_INSTANCE_ID=codex-db  (optional: specific RDS instance identifier)
# For GCP: set INFRA_BACKEND=gcp and set GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# GCS_BUCKET=your-gcs-bucket (optional: GCS bucket to check location)
